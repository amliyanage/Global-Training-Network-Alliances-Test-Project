    {
      "name": "Bookings",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"paymentMethod\": \"online\",\n    \"customer\": {\n        \"firstName\": \"{{customer_first_name}}\",\n        \"lastName\": \"{{customer_last_name}}\",\n        \"email\": \"{{customer_email}}\",\n        \"phone\": \"{{customer_phone}}\",\n        \"address\": \"{{customer_address}}\",\n        \"city\": \"{{customer_city}}\",\n        \"country\": \"{{customer_country}}\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/bookings/checkout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookings",
                "checkout"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (e) {",
                  "  json = {};",
                  "}",
                  "",
                  "const booking = json.booking || json;",
                  "if (booking && booking._id) {",
                  "  pm.collectionVariables.set(\"booking_id\", booking._id);",
                  "}",
                  "",
                  "if (booking && booking.paymentOrderId) {",
                  "  pm.collectionVariables.set(\"payment_order_id\", booking.paymentOrderId);",
                  "}",
                  "",
                  "if (booking && booking.totalAmount !== undefined) {",
                  "  const parsed = Number(booking.totalAmount);",
                  "  if (!Number.isNaN(parsed)) {",
                  "    pm.collectionVariables.set(\"payhere_amount\", parsed.toFixed(2));",
                  "  }",
                  "}",
                  "",
                  "if (json.paymentSession && json.paymentSession.payload) {",
                  "  const payload = json.paymentSession.payload;",
                  "  if (payload.order_id) pm.collectionVariables.set(\"payment_order_id\", payload.order_id);",
                  "  if (payload.amount) pm.collectionVariables.set(\"payhere_amount\", payload.amount);",
                  "  if (payload.custom_1) pm.collectionVariables.set(\"booking_id\", payload.custom_1);",
                  "  if (payload.custom_2) pm.collectionVariables.set(\"user_id\", payload.custom_2);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "PayHere Notify (Simulate)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "merchant_id",
                  "value": "{{payhere_merchant_id}}",
                  "type": "text"
                },
                {
                  "key": "order_id",
                  "value": "{{payment_order_id}}",
                  "type": "text"
                },
                {
                  "key": "payment_id",
                  "value": "{{payhere_payment_id}}",
                  "type": "text"
                },
                {
                  "key": "payhere_amount",
                  "value": "{{payhere_amount}}",
                  "type": "text"
                },
                {
                  "key": "payhere_currency",
                  "value": "{{payhere_currency}}",
                  "type": "text"
                },
                {
                  "key": "status_code",
                  "value": "{{payhere_status_code}}",
                  "type": "text"
                },
                {
                  "key": "md5sig",
                  "value": "{{payhere_md5sig}}",
                  "type": "text"
                },
                {
                  "key": "method",
                  "value": "{{payhere_method}}",
                  "type": "text"
                },
                {
                  "key": "status_message",
                  "value": "{{payhere_status_message}}",
                  "type": "text"
                },
                {
                  "key": "custom_1",
                  "value": "{{booking_id}}",
                  "type": "text"
                },
                {
                  "key": "custom_2",
                  "value": "{{user_id}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/bookings/payhere/notify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookings",
                "payhere",
                "notify"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const merchantId = pm.collectionVariables.get(\"payhere_merchant_id\");",
                  "const merchantSecret = pm.collectionVariables.get(\"payhere_merchant_secret\");",
                  "const orderId = pm.collectionVariables.get(\"payment_order_id\");",
                  "const amountRaw = pm.collectionVariables.get(\"payhere_amount\");",
                  "const currency = (pm.collectionVariables.get(\"payhere_currency\") || \"LKR\").toUpperCase();",
                  "const statusCode = pm.collectionVariables.get(\"payhere_status_code\") || \"2\";",
                  "",
                  "if (!merchantId || !merchantSecret || !orderId || !amountRaw) {",
                  "  throw new Error(\"Missing PayHere vars: payhere_merchant_id, payhere_merchant_secret, payment_order_id, payhere_amount\");",
                  "}",
                  "",
                  "const parsedAmount = Number(amountRaw);",
                  "if (Number.isNaN(parsedAmount)) {",
                  "  throw new Error(\"payhere_amount must be a number\");",
                  "}",
                  "",
                  "const amount = parsedAmount.toFixed(2);",
                  "pm.collectionVariables.set(\"payhere_amount\", amount);",
                  "pm.collectionVariables.set(\"payhere_currency\", currency);",
                  "",
                  "const hashedSecret = CryptoJS.MD5(merchantSecret).toString().toUpperCase();",
                  "const md5sig = CryptoJS.MD5(`${merchantId}${orderId}${amount}${currency}${statusCode}${hashedSecret}`)",
                  "  .toString()",
                  "  .toUpperCase();",
                  "",
                  "pm.collectionVariables.set(\"payhere_md5sig\", md5sig);"
                ]
              }
            }
          ]
        },
